using UnityEngine;
using UnityEngine.Video;

public class VideoController : MonoBehaviour
{
    public static VideoController Instance;

    [Header("视频设置")]
    public VideoPlayer videoPlayer;
    public AudioSource audioSource;
    public GameObject videoScreen;

    [Header("播放控制")]
    public bool loop = true;

    [Header("交互控制")]
    public float interactionRange = 5f;
    public KeyCode playKey = KeyCode.E;

    private Transform playerTransform;

    private void Awake()
    {
        if (Instance == null)
        {
            Instance = this;
            Debug.Log("✅ VideoController 已初始化");
        }
        else
        {
            Destroy(gameObject);
            return;
        }
    }

    void Start()
    {
        // ===== 强制停止所有视频 =====
        VideoPlayer[] allPlayers = FindObjectsOfType<VideoPlayer>();
        foreach (VideoPlayer vp in allPlayers)
        {
            vp.playOnAwake = false;
            vp.Stop();
            vp.enabled = false;
            Debug.Log($"⏹️ 已停止视频：{vp.name}");
        }

        GameObject player = GameObject.FindGameObjectWithTag("Player");
        if (player != null)
            playerTransform = player.transform;

        if (videoPlayer != null)
        {
            videoPlayer.enabled = false;
            videoPlayer.playOnAwake = false;
            videoPlayer.isLooping = loop;
            videoPlayer.targetMaterialProperty = "_MainTex";

            if (audioSource != null)
            {
                videoPlayer.audioOutputMode = VideoAudioOutputMode.AudioSource;
                videoPlayer.SetTargetAudioSource(0, audioSource);

                // ===== 视频音量跟随全局音量 =====
                ApplyGlobalVolume();
            }

            Debug.Log("🎬 视频已就绪，等待播放");
        }
        else
        {
            Debug.LogError("❌ videoPlayer 为空！请拖入引用！");
        }

        if (videoScreen != null)
            videoScreen.SetActive(true);
    }

    void Update()
    {
        if (videoPlayer == null) return;

        if (Input.GetKeyDown(playKey) && playerTransform != null)
        {
            float distance = Vector3.Distance(playerTransform.position, transform.position);
            if (distance < interactionRange)
            {
                ToggleVideo();
            }
        }

        // ===== 实时同步全局音量 =====
        if (audioSource != null && AudioManager.Instance != null)
        {
            audioSource.volume = AudioManager.Instance.GetMasterVolume();
        }
    }

    public void PlayVideo()
    {
        if (videoPlayer == null)
        {
            Debug.LogError("❌ videoPlayer 为空！");
            return;
        }

        // 应用全局音量
        ApplyGlobalVolume();

        videoPlayer.enabled = true;
        videoPlayer.Play();
        Debug.Log("▶️ 视频开始播放");
    }

    public void PauseVideo()
    {
        if (videoPlayer == null) return;
        videoPlayer.Pause();
        Debug.Log("⏸️ 视频暂停");
    }

    public void StopVideo()
    {
        if (videoPlayer == null) return;
        videoPlayer.Stop();
        videoPlayer.enabled = false;
        Debug.Log("⏹️ 视频停止");
    }

    public void ToggleVideo()
    {
        if (videoPlayer == null) return;

        if (videoPlayer.isPlaying)
        {
            PauseVideo();
        }
        else
        {
            PlayVideo();
        }
    }

    public bool IsPlaying()
    {
        return videoPlayer != null && videoPlayer.isPlaying;
    }

    // ===== 应用全局音量到视频音频 =====
    void ApplyGlobalVolume()
    {
        if (audioSource == null) return;

        if (AudioManager.Instance != null)
        {
            audioSource.volume = AudioManager.Instance.GetMasterVolume();
            Debug.Log($"🎵 视频音量同步：{audioSource.volume * 100:F0}%");
        }
        else if (BackgroundMusicController.Instance != null)
        {
            audioSource.volume = BackgroundMusicController.Instance.GetVolume();
        }
        else
        {
            audioSource.volume = 0.5f;  // 默认音量
        }
    }

    // ===== 手动设置视频音量 =====
    public void SetVolume(float volume)
    {
        if (audioSource == null) return;
        audioSource.volume = Mathf.Clamp01(volume);
    }
}
