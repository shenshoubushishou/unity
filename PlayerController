using UnityEngine;

public class PlayerController : MonoBehaviour
{
    [Header("移动设置")]
    public float walkSpeed = 5000f;          // 1秒走10个单位
    public float sprintSpeed = 9999f;        // 冲刺1秒走20个单位
    public float gravity = -117.72f;
    public float jumpHeight = 18f;

    [Header("冲刺设置")]
    public float sprintStaminaCost = 1000f;
    public float maxStamina = 9999f;
    public float staminaRegenRate = 20f;

    private CharacterController controller;
    private Vector3 velocity;

    private float currentStamina;
    private bool isSprinting = false;
    private bool isMouseLocked = true;

    private CameraController cameraController;

    void Start()
    {
        controller = GetComponent<CharacterController>();
        Cursor.lockState = CursorLockMode.Locked;
        currentStamina = maxStamina;
        isMouseLocked = true;

        cameraController = GetComponent<CameraController>();
    }

    void Update()
    {
        if (Input.GetKeyDown(KeyCode.LeftAlt) || Input.GetKeyDown(KeyCode.RightAlt))
        {
            ToggleMouseLock();
        }
        // 注释掉 controller.Move
        // controller.Move(moveDirection * currentSpeed * Time.deltaTime);

        // 用 Translate 直接移动
        

        GameObject mainMenu = GameObject.Find("MainMenuCanvas");
        if (mainMenu != null && mainMenu.activeSelf)
            return;

        if (!isMouseLocked)
            return;

        float horizontal = Input.GetAxis("Horizontal");
        float vertical = Input.GetAxis("Vertical");

        bool sprintInput = Input.GetKey(KeyCode.LeftShift) || Input.GetKey(KeyCode.RightShift);
        bool canSprint = sprintInput && currentStamina > 0 && (horizontal != 0 || vertical != 0);

        float currentSpeed = canSprint ? sprintSpeed : walkSpeed;
        isSprinting = canSprint;

        Vector3 moveDirection = GetMoveDirection(horizontal, vertical);

        if (moveDirection.magnitude > 0.1f)
        {
            controller.Move(moveDirection * currentSpeed * Time.deltaTime);
            //transform.Translate(moveDirection * currentSpeed * Time.deltaTime);
            Quaternion targetRotation = Quaternion.LookRotation(moveDirection);
            transform.rotation = Quaternion.Slerp(transform.rotation, targetRotation, Time.deltaTime * 10f);
        }

        if (isSprinting)
        {
            currentStamina -= sprintStaminaCost * Time.deltaTime;
            if (currentStamina < 0) currentStamina = 0;
        }
        else
        {
            currentStamina += staminaRegenRate * Time.deltaTime;
            if (currentStamina > maxStamina) currentStamina = maxStamina;
        }

        if (controller.isGrounded && velocity.y < 0)
        {
            velocity.y = -2f;
        }
        velocity.y += gravity * Time.deltaTime;
        controller.Move(velocity * Time.deltaTime);

        if (controller.isGrounded && Input.GetButtonDown("Jump"))
        {
            velocity.y = Mathf.Sqrt(jumpHeight * -2f * gravity);
        }
    }

    Vector3 GetMoveDirection(float horizontal, float vertical)
    {
        Transform cameraTransform = GetActiveCamera();

        if (cameraTransform == null)
        {
            return transform.right * horizontal + transform.forward * vertical;
        }

        Vector3 cameraRight = cameraTransform.right;
        Vector3 cameraForward = cameraTransform.forward;

        cameraForward.y = 0;
        cameraForward.Normalize();

        cameraRight.y = 0;
        cameraRight.Normalize();

        Vector3 moveDir = cameraRight * horizontal + cameraForward * vertical;

        if (moveDir.magnitude < 0.01f)
            return Vector3.zero;

        return moveDir.normalized;
    }

    Transform GetActiveCamera()
    {
        if (cameraController != null)
        {
            if (cameraController.isFirstPerson)
            {
                return cameraController.firstPersonCamera;
            }
            else
            {
                return cameraController.thirdPersonCamera;
            }
        }

        Camera mainCam = Camera.main;
        if (mainCam != null)
            return mainCam.transform;

        return null;
    }

    void ToggleMouseLock()
    {
        isMouseLocked = !isMouseLocked;

        if (isMouseLocked)
        {
            Cursor.lockState = CursorLockMode.Locked;
            Cursor.visible = false;
        }
        else
        {
            Cursor.lockState = CursorLockMode.None;
            Cursor.visible = true;
        }
    }

    public float GetStamina()
    {
        return currentStamina / maxStamina;
    }

    public bool IsSprinting()
    {
        return isSprinting;
    }

    public float GetCurrentSpeed()
    {
        return isSprinting ? sprintSpeed : walkSpeed;
    }
}
