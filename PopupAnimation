using UnityEngine;
using TMPro;
using System.Collections;

public class PopupAnimation : MonoBehaviour
{
    public float floatSpeed = 60f;
    public float destroyDelay = 1.8f;

    private TMP_Text text;
    private Color originalColor;
    private RectTransform rect;

    void Start()
    {
        text = GetComponent<TMP_Text>();
        rect = GetComponent<RectTransform>();

        if (text != null)
        {
            originalColor = text.color;
            text.color = new Color(originalColor.r, originalColor.g, originalColor.b, 1f);
        }

        StartCoroutine(AnimatePopup());
    }

    IEnumerator AnimatePopup()
    {
        float elapsed = 0f;
        Vector2 startPos = rect != null ? rect.anchoredPosition : Vector2.zero;

        while (elapsed < destroyDelay)
        {
            elapsed += Time.deltaTime;

            // 向上飘
            if (rect != null)
            {
                rect.anchoredPosition = startPos + Vector2.up * floatSpeed * elapsed;
            }

            // 淡出
            if (text != null)
            {
                float alpha = 1f;
                if (elapsed > destroyDelay - 0.5f)
                {
                    float t = (elapsed - (destroyDelay - 0.5f)) / 0.5f;
                    alpha = Mathf.Lerp(1f, 0f, t);
                }
                text.color = new Color(originalColor.r, originalColor.g, originalColor.b, alpha);
            }

            yield return null;
        }

        Destroy(gameObject);
    }
}
